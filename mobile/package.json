{
  "name": "sante-aproxmite-mobile",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "prestart": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$p=(Get-NetTCPConnection -LocalPort 8082 -State Listen -ErrorAction SilentlyContinue | Select-Object -ExpandProperty OwningProcess -First 1); if ($p) { Stop-Process -Id $p -Force }\"",
    "start": "set CI=1&& expo start --lan --port 8082",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:android": "eas build --platform android --profile production",
    "build:android:preview": "eas build --platform android --profile preview"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "dotenv": "^17.3.1",
    "expo": "^54.0.0",
    "expo-image-picker": "~17.0.8",
    "expo-location": "~19.0.8",
    "expo-sqlite": "~16.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-maps": "1.20.1"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@react-native-community/cli-server-api": "^20.1.2",
    "babel-preset-expo": "^54.0.0"
  }
}
